{
  "profile": "ultra-stability-fallback-v1",
  "description": "Emergency low-memory profile for hosts where other training profiles are OOM-killed.",
  "tokenizer": "o200k_base",
  "extra_corpus": "data/csharp_instruction_seed.txt",
  "extra_weight": 4,
  "vocab_size": 32000,
  "seq_len": 192,
  "micro_batch_size": 1,
  "grad_accum_steps": 1,
  "steps": 3000,
  "d_model": 384,
  "n_heads": 6,
  "n_layers": 6,
  "dropout": 0.1,
  "lr": 0.0002,
  "log_every": 50,
  "eval_every": 200,
  "eval_steps": 8,
  "save_every": 200,
  "amp": true,
  "resume": false,
  "high_signal_weight_threshold": 8,
  "priority_token_ratio": 0.35,
  "min_available_memory_gb": 0,
  "corpus_weights": {
    "data/csharp_instruction_seed.txt": 6,
    "data/corpus_dotnet_focus.txt": 6,
    "data/prompt_interpretation_focus.txt": 6,
    "data/dotnet_csharp_sft_pairs.txt": 12,
    "data/github_csharp_quality_corpus.txt": 2,
    "data/feedback_corpus.txt": 10
  }
}
