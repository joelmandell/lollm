@page "/"
@inject AgentApiClient ApiClient
@using Markdig
@using Microsoft.AspNetCore.Components
@using System.Net

<PageTitle>Home</PageTitle>

<h1>DotNet Coding Agent</h1>

<p>Chat with your locally trained model or run agentic code generation grounded in indexed .NET/C# docs and repositories.</p>

<div class="card mb-4">
    <div class="card-header">Local Model Status</div>
    <div class="card-body">
        @if (modelStatus is null)
        {
            <p class="mb-2">Status unavailable.</p>
        }
        else
        {
            <p class="mb-1"><strong>Vocabulary:</strong> @modelStatus.VocabularySize</p>
            <p class="mb-1"><strong>Total tokens:</strong> @modelStatus.TotalTokens</p>
            <p class="mb-3"><strong>Last trained:</strong> @(modelStatus.LastTrainedUtc?.ToString("u") ?? "Never")</p>
        }
        <button class="btn btn-outline-primary" @onclick="TrainModelAsync" disabled="@isBusy">Train Model</button>
    </div>
</div>

<div class="mb-4">
    <h3>Chat</h3>
    <div class="mb-3">
        <label class="form-label">Prompt</label>
        <textarea class="form-control" @bind="chatPrompt" rows="4"></textarea>
    </div>
    <button class="btn btn-primary" @onclick="RunChatAsync" disabled="@isBusy">Ask</button>
</div>

@if (!string.IsNullOrWhiteSpace(chatAnswer))
{
    <div class="card mb-4">
        <div class="card-header">Chat Answer</div>
        <div class="card-body">
            @((MarkupString)RenderResponse(chatAnswer))
        </div>
    </div>
}

<div class="mb-4">
    <h3>Generate Code</h3>
    <div class="mb-3">
        <label class="form-label">Task</label>
        <textarea class="form-control" @bind="codeTask" rows="6"></textarea>
    </div>
    <button class="btn btn-success" @onclick="RunCodeGenerationAsync" disabled="@isBusy">Generate</button>
</div>

@if (!string.IsNullOrWhiteSpace(codePlan))
{
    <div class="card mb-3">
        <div class="card-header">Plan</div>
        <div class="card-body">
            @((MarkupString)RenderResponse(codePlan))
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(codeOutput))
{
    <div class="card">
        <div class="card-header">Generated Code + Notes</div>
        <div class="card-body">
            @((MarkupString)RenderResponse(codeOutput))
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger mt-4">@error</div>
}

@if (isBusy)
{
    <div class="alert alert-secondary mt-4">Working...</div>
}

@code {
    private string chatPrompt = "How should I design a resilient HttpClient in .NET 10?";
    private string chatAnswer = string.Empty;
    private string codeTask = "Create a C# service that retries HTTP calls with exponential backoff and cancellation support.";
    private string codePlan = string.Empty;
    private string codeOutput = string.Empty;
    private string error = string.Empty;
    private bool isBusy;
    private ModelStatusResponse? modelStatus;

    protected override async Task OnInitializedAsync()
    {
        await RefreshModelStatusAsync();
    }

    private async Task RunChatAsync()
    {
        isBusy = true;
        error = string.Empty;
        try
        {
            var response = await ApiClient.ChatAsync(new ChatRequest(chatPrompt));
            chatAnswer = response?.Answer ?? "No answer returned.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RunCodeGenerationAsync()
    {
        isBusy = true;
        error = string.Empty;
        try
        {
            var response = await ApiClient.GenerateCodeAsync(new GenerateCodeRequest(codeTask));
            codePlan = response?.Plan ?? "No plan returned.";
            codeOutput = response?.Code ?? "No code returned.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task TrainModelAsync()
    {
        isBusy = true;
        error = string.Empty;
        try
        {
            var response = await ApiClient.TrainModelAsync(epochs: 1);
            if (response is not null)
            {
                chatAnswer = response.Message;
            }

            await RefreshModelStatusAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RefreshModelStatusAsync()
    {
        modelStatus = await ApiClient.GetModelStatusAsync();
    }

    private static string RenderResponse(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        if (LooksLikeMarkdown(value))
        {
            return Markdown.ToHtml(value);
        }

        return $"<pre>{WebUtility.HtmlEncode(value)}</pre>";
    }

    private static bool LooksLikeMarkdown(string value)
    {
        return value.Contains("```", StringComparison.Ordinal)
            || value.Contains("# ", StringComparison.Ordinal)
            || value.Contains("## ", StringComparison.Ordinal)
            || value.Contains("- ", StringComparison.Ordinal)
            || value.Contains("1. ", StringComparison.Ordinal)
            || value.Contains("**", StringComparison.Ordinal)
            || value.Contains("`", StringComparison.Ordinal);
    }
}
