@page "/training"
@inject AgentApiClient ApiClient
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Model Training</PageTitle>

<h1>Model Setup and Retraining</h1>
<p>Bootstrap default sources (.NET 10, EF Core, Aspire, MDN JavaScript, and GitHub repos), ingest content, and retrain the local model.</p>

<div class="card mb-4">
    <div class="card-header">Quick Start</div>
    <div class="card-body">
        <button class="btn btn-primary me-2" @onclick="SeedDefaultsAsync" disabled="@isBusy">Seed Default Sources</button>
        <button class="btn btn-secondary me-2" @onclick="IngestAllAsync" disabled="@isBusy">Ingest All Sources</button>
        <button class="btn btn-success" @onclick="BootstrapAsync" disabled="@isBusy">Bootstrap (Seed + Ingest + Train)</button>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Train Local Model</div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Epochs</label>
            <input class="form-control" type="number" min="1" max="20" @bind="epochs" />
        </div>
        <button class="btn btn-outline-success" @onclick="TrainAsync" disabled="@isBusy">Retrain Model</button>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Train from Project Zip</div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Project tag</label>
            <input class="form-control" @bind="projectTag" />
        </div>
        <div class="mb-3">
            <label class="form-label">Project zip (.zip)</label>
            <InputFile OnChange="OnProjectZipSelected" accept=".zip" />
            @if (!string.IsNullOrWhiteSpace(selectedZipName))
            {
                <p class="mt-2 mb-0"><strong>Selected:</strong> @selectedZipName</p>
            }
        </div>
        <button class="btn btn-outline-primary" @onclick="TrainProjectZipAsync" disabled="@isBusy">Upload + Train Project</button>
        @if (projectTrainResult is not null)
        {
            <p class="mt-3 mb-1"><strong>Project:</strong> @projectTrainResult.ProjectTag</p>
            <p class="mb-1"><strong>Files indexed:</strong> @projectTrainResult.FilesIndexed</p>
            <p class="mb-1"><strong>Chunks indexed:</strong> @projectTrainResult.ChunkCount</p>
            <p class="mb-0"><strong>Trained chunks:</strong> @projectTrainResult.TrainedChunks</p>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Quality Benchmark</div>
    <div class="card-body">
        <button class="btn btn-outline-dark" @onclick="RunBenchmarkAsync" disabled="@isBusy">Run Benchmark</button>
        @if (benchmark is not null)
        {
            <p class="mt-3 mb-1"><strong>Average score:</strong> @benchmark.AverageScore</p>
            <p class="mb-0"><strong>Cases:</strong> @benchmark.CaseCount</p>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Model Stack Backend</div>
    <div class="card-body">
        <button class="btn btn-outline-primary me-2" @onclick="CheckBackendAsync" disabled="@isBusy">Check Backend</button>
        <button class="btn btn-outline-secondary" @onclick="ExportCorpusAsync" disabled="@isBusy">Export Corpus</button>
        @if (backendStatus is not null)
        {
            <p class="mt-3 mb-1"><strong>Provider:</strong> @backendStatus.Provider</p>
            <p class="mb-1"><strong>Transformer URL:</strong> @backendStatus.TransformerBaseUrl</p>
            <p class="mb-0"><strong>Transformer healthy:</strong> @backendStatus.TransformerHealthy</p>
        }
        @if (exportResult is not null)
        {
            <p class="mt-3 mb-1"><strong>Exported chunks:</strong> @exportResult.ChunkCount</p>
            <p class="mb-1"><strong>JSONL:</strong> @(exportResult.JsonlPath ?? "disabled")</p>
            <p class="mb-0"><strong>Text:</strong> @(exportResult.TextPath ?? "disabled")</p>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Model Status</div>
    <div class="card-body">
        @if (status is null)
        {
            <p class="mb-0">No model status available.</p>
        }
        else
        {
            <p class="mb-1"><strong>Vocabulary:</strong> @status.VocabularySize</p>
            <p class="mb-1"><strong>Total tokens:</strong> @status.TotalTokens</p>
            <p class="mb-1"><strong>Model path:</strong> @status.ModelPath</p>
            <p class="mb-0"><strong>Last trained:</strong> @(status.LastTrainedUtc?.ToString("u") ?? "Never")</p>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info">@message</div>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

@code {
    private int epochs = 1;
    private bool isBusy;
    private string message = string.Empty;
    private string error = string.Empty;
    private ModelStatusResponse? status;
    private ModelBenchmarkResponse? benchmark;
    private BackendStatusResponse? backendStatus;
    private ExportCorpusResponse? exportResult;
    private IBrowserFile? selectedProjectZip;
    private string selectedZipName = string.Empty;
    private string projectTag = "my-project";
    private ProjectZipTrainingResponse? projectTrainResult;

    protected override async Task OnInitializedAsync()
    {
        await RefreshStatusAsync();
    }

    private async Task SeedDefaultsAsync()
    {
        isBusy = true;
        error = string.Empty;
        message = string.Empty;
        try
        {
            var response = await ApiClient.SeedDefaultSourcesAsync();
            message = response?.Message ?? "Default sources seeded.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task IngestAllAsync()
    {
        isBusy = true;
        error = string.Empty;
        message = string.Empty;
        try
        {
            var response = await ApiClient.IngestAsync(null, force: true);
            message = response?.Message ?? "Ingest complete.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task TrainAsync()
    {
        isBusy = true;
        error = string.Empty;
        message = string.Empty;
        try
        {
            var response = await ApiClient.TrainModelAsync(epochs);
            message = response?.Message ?? "Training complete.";
            await RefreshStatusAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task BootstrapAsync()
    {
        isBusy = true;
        error = string.Empty;
        message = string.Empty;
        try
        {
            var response = await ApiClient.BootstrapTrainingAsync(new BootstrapTrainingRequest(true, true, epochs));
            message = response?.Message ?? "Bootstrap complete.";
            await RefreshStatusAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RunBenchmarkAsync()
    {
        isBusy = true;
        error = string.Empty;
        message = string.Empty;
        try
        {
            benchmark = await ApiClient.BenchmarkAsync(10);
            message = benchmark is null
                ? "No benchmark response."
                : $"Benchmark completed. Average score: {benchmark.AverageScore}.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RefreshStatusAsync()
    {
        status = await ApiClient.GetModelStatusAsync();
    }

    private async Task CheckBackendAsync()
    {
        isBusy = true;
        error = string.Empty;
        message = string.Empty;
        try
        {
            backendStatus = await ApiClient.GetBackendStatusAsync();
            message = backendStatus is null ? "No backend status returned." : "Backend status updated.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ExportCorpusAsync()
    {
        isBusy = true;
        error = string.Empty;
        message = string.Empty;
        try
        {
            exportResult = await ApiClient.ExportCorpusAsync(true, true);
            message = exportResult?.Message ?? "Corpus exported.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OnProjectZipSelected(InputFileChangeEventArgs args)
    {
        selectedProjectZip = args.File;
        selectedZipName = selectedProjectZip?.Name ?? string.Empty;
    }

    private async Task TrainProjectZipAsync()
    {
        isBusy = true;
        error = string.Empty;
        message = string.Empty;
        try
        {
            if (selectedProjectZip is null)
            {
                throw new InvalidOperationException("Select a .zip file first.");
            }

            projectTrainResult = await ApiClient.TrainProjectZipAsync(projectTag, selectedProjectZip, epochs);
            message = projectTrainResult?.Message ?? "Project training complete.";
            await RefreshStatusAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }
}
