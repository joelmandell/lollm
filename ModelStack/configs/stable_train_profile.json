{
  "profile": "stability-fallback-v1",
  "description": "Lower-memory fallback profile used when scale-up profile is terminated (e.g., OOM).",
  "tokenizer": "o200k_base",
  "extra_corpus": "data/csharp_instruction_seed.txt",
  "extra_weight": 4,
  "vocab_size": 36000,
  "seq_len": 256,
  "micro_batch_size": 1,
  "grad_accum_steps": 2,
  "steps": 5000,
  "d_model": 512,
  "n_heads": 8,
  "n_layers": 8,
  "dropout": 0.1,
  "lr": 0.00025,
  "log_every": 50,
  "eval_every": 250,
  "eval_steps": 12,
  "save_every": 250,
  "amp": true,
  "resume": false,
  "high_signal_weight_threshold": 8,
  "priority_token_ratio": 0.35,
  "min_available_memory_gb": 8,
  "corpus_weights": {
    "data/csharp_instruction_seed.txt": 6,
    "data/corpus_dotnet_focus.txt": 6,
    "data/prompt_interpretation_focus.txt": 6,
    "data/dotnet_csharp_sft_pairs.txt": 12,
    "data/github_csharp_quality_corpus.txt": 2,
    "data/feedback_corpus.txt": 10
  }
}
